# Kubeflow Configuration
# Copy this file to kubeflow.env and update with your actual credentials
# Then source it: source kubeflow.env

# Kubeflow endpoint (usually localhost with port-forward)
export KUBEFLOW_ENDPOINT=http://localhost:8080

# Dex authentication credentials
# Default credentials for local Kubeflow installations
export KUBEFLOW_USERNAME=user@example.com
export KUBEFLOW_PASSWORD=12341234

# User namespace - check your Kubeflow UI for the correct namespace
# Usually in format: kubeflow-user-{email-prefix}
export KUBEFLOW_USER_NAMESPACE=kubeflow-user-example-com

# Legacy namespace (for older APIs)
export KUBEFLOW_NAMESPACE=kubeflow 